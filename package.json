{
  "name": "mf-shared-dependency-monitor",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "extension dev --browser=chrome,firefox",
    "dev:chrome": "extension dev --browser=chrome",
    "dev:firefox": "extension dev --browser=firefox",
    "dev:edge": "extension dev --browser=edge",
    "start": "extension start --browser=chrome",
    "preview": "extension preview --browser=chrome",
    "build": "extension build --browser=chrome,edge,firefox --zip",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck"
  },
  "dependencies": {
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "chrome-types": "^0.1.361",
    "extension": "^3.18.2",
    "sass": "^1.95.1",
    "typescript": "^5.8.3"
  }
}
